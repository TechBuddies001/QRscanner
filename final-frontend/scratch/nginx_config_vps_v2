# HTTP Redirects
server {
    listen 80;
    server_name tarkshyasolution.in www.tarkshyasolution.in;
    return 301 https://$host$request_uri;
}

server {
    if ($host = admin.tarkshyasolution.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    server_name admin.tarkshyasolution.in;

    listen 80;
    return 404; # managed by Certbot


}
